ADMIN_PASSWORD=your_secure_admin_password

# Email (SMTP) — required for confirmation emails when bookings are approved
# Gmail example: enable "App Passwords" under your Google account security settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_gmail@gmail.com
